<Page x:Class="vokzal.EducationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Образование сотрудника">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding EmployeeName}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListView Grid.Row="1" Name="EducationListView" Margin="0,0,0,10"
          SelectionChanged="EducationListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Уровень" DisplayMemberBinding="{Binding EducationLevel}" Width="150"/>
                    <GridViewColumn Header="Учебное заведение" DisplayMemberBinding="{Binding InstitutionName}" Width="300"/>
                    <GridViewColumn Header="Год окончания" DisplayMemberBinding="{Binding GraduationYear}" Width="120"/>
                </GridView>
            </ListView.View>
        </ListView>

        <GroupBox Grid.Row="2" Header="Добавить/Редактировать образование" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Уровень:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Name="EducationLevelComboBox" Margin="5" Height="25">
                    <ComboBoxItem Content="Среднее"/>
                    <ComboBoxItem Content="Среднее специальное"/>
                    <ComboBoxItem Content="Высшее"/>
                    <ComboBoxItem Content="Неоконченное высшее"/>
                    <ComboBoxItem Content="Аспирантура"/>
                    <ComboBoxItem Content="Докторантура"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Учебное заведение:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Name="InstitutionTBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Год окончания:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Name="GraduationYearTBox" Margin="5" Height="25" ToolTip="Год от 1900 до текущего"/>

                <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Orientation="Vertical" Margin="10,0,0,0">
                    <Button Name="AddEducationBtn" Content="Добавить" Click="AddEducationBtn_Click" Width="100" Margin="0,5"/>
                    <Button Name="UpdateEducationBtn" Content="Обновить" Click="UpdateEducationBtn_Click" Width="100" Margin="0,5"/>
                    <Button Name="DeleteEducationBtn" Content="Удалить" Click="DeleteEducationBtn_Click" Width="100" Margin="0,5"/>
                    <Button Name="ClearFormBtn" Content="Очистить" Click="ClearFormBtn_Click" Width="100" Margin="0,5"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Page>