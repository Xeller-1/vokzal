<Page x:Class="vokzal.CrewManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление бригадами"
      Loaded="Page_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление бригадами поездов" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListView Name="CrewListView" Grid.Row="1" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Поезд" DisplayMemberBinding="{Binding TrainNumber}" Width="120"/>
                    <GridViewColumn Header="Бригада" DisplayMemberBinding="{Binding CrewTitle}" Width="180"/>
                    <GridViewColumn Header="Состав сотрудников" DisplayMemberBinding="{Binding MembersSummary}" Width="520"/>
                    <GridViewColumn Header="Кол-во" DisplayMemberBinding="{Binding MembersCount}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="AddCrewBtn" Content="Добавить бригаду" Click="AddCrewBtn_Click" Width="150" Margin="5" Background="#4CAF50" Foreground="White"/>
            <Button Name="EditCrewBtn" Content="Состав бригады" Click="EditCrewBtn_Click" Width="150" Margin="5" Background="#2196F3" Foreground="White"/>
            <Button Name="DeleteCrewBtn" Content="Удалить бригаду" Click="DeleteCrewBtn_Click" Width="150" Margin="5" Background="#f44336" Foreground="White"/>
        </StackPanel>
    </Grid>
</Page>
