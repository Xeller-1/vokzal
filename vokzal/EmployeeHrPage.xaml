<Page x:Class="vokzal.EmployeeHrPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HR данные сотрудника">
    <Grid Margin="15">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B1223" Offset="0"/>
                <GradientStop Color="#111827" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,12">
            <StackPanel>
            <TextBlock x:Name="EmployeeNameText" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="HireDateText" FontSize="14" Margin="0,4,0,0"/>
            <TextBlock x:Name="CurrentPositionText" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="История должностей" Grid.Column="0" Margin="0,0,8,0" Background="#0F172A" BorderBrush="#334155">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView x:Name="PositionHistoryList" Grid.Row="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Должность" DisplayMemberBinding="{Binding PositionName}" Width="170"/>
                                <GridViewColumn Header="С" DisplayMemberBinding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                                <GridViewColumn Header="По" DisplayMemberBinding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <ComboBox x:Name="PositionCombo" Width="180" DisplayMemberPath="PositionName" SelectedValuePath="PositionID"/>
                        <DatePicker x:Name="PositionStartDatePicker" Width="130" Margin="8,0,0,0"/>
                        <Button Content="Добавить" Click="AddPositionHistory_Click" Width="100" Margin="8,0,0,0" Background="#5B6CFF"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="Отпуска" Grid.Column="1" Margin="8,0,0,0" Background="#0F172A" BorderBrush="#334155">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView x:Name="VacationList" Grid.Row="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="С" DisplayMemberBinding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                                <GridViewColumn Header="По" DisplayMemberBinding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                                <GridViewColumn Header="Причина" DisplayMemberBinding="{Binding Reason}" Width="170"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <DatePicker x:Name="VacationStartDatePicker" Width="130"/>
                        <DatePicker x:Name="VacationEndDatePicker" Width="130" Margin="8,0,0,0"/>
                        <TextBox x:Name="VacationReasonTextBox" Width="170" Margin="8,0,0,0"/>
                        <Button Content="Добавить + PDF" Click="AddVacation_Click" Width="130" Margin="8,0,0,0" Background="#14B8A6"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Назад" Width="120" Click="Back_Click"/>
        </StackPanel>
        </Border>
    </Grid>
</Page>
