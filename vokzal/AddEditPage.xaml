<Page x:Class="vokzal.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Добавление/Редактирование сотрудника">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding EmployeeID, StringFormat='Редактирование сотрудника №{0}'}" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"
                   Name="EditTitle"/>
        <TextBlock Grid.Row="0" Text="Добавление нового сотрудника" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"
                   Name="AddTitle"/>

        <GroupBox Grid.Row="1" Header="Основная информация" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LastName}" Margin="5" Height="25"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FirstName}" Margin="5" Height="25"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MiddleName}" Margin="5" Height="25"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата рождения:" Margin="5" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding BirthDate}" Margin="5" Height="25" Name="BirthDatePicker"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата приема:" Margin="5" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding HireDate}" Margin="5" Height="25" Name="HireDatePicker"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Адрес проживания:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Address}" Margin="5" Height="25"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Адрес регистрации:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Registration}" Margin="5" Height="25"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Телефон:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Phone}" Margin="5" Height="25"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Должность:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="8" Grid.Column="1" Name="PositionComboBox" Margin="5" Height="25"
                         DisplayMemberPath="PositionName" SelectedValuePath="PositionID"
                         SelectedValue="{Binding PositionID}"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Пол:" Margin="5" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="5">
                    <RadioButton Name="MaleRBtn" Content="Мужской" GroupName="Gender"/>
                    <RadioButton Name="FemaleRBtn" Content="Женский" GroupName="Gender" Margin="20,0,0,0"/>
                </StackPanel>

                <!-- Фото -->
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Фото сотрудника:" Margin="5" VerticalAlignment="Center" 
                          Grid.RowSpan="2" HorizontalAlignment="Center"/>
                <Image Grid.Row="2" Grid.Column="2" Grid.RowSpan="6" Name="PhotoPeople" 
                       Width="200" Height="200" Margin="5" Stretch="UniformToFill">
                    <Image.Source>
                        <Binding Path="Photo">
                            <Binding.TargetNullValue>
                                <ImageSource>/Resources/service.png</ImageSource>
                            </Binding.TargetNullValue>
                        </Binding>
                    </Image.Source>
                </Image>
                <Button Grid.Row="8" Grid.Column="2" Name="ChangePhoto" Content="Изменить фото" 
                        Click="ChangePhoto_Click" Width="120" Height="30" Margin="5"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Name="SaveBtn" Content="Сохранить" Click="SaveBtn_Click" Width="100" Margin="5"/>
            <Button Name="CancelBtn" Content="Отмена" Click="CancelBtn_Click" Width="100" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>