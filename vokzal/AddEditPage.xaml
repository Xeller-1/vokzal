<Page x:Class="vokzal.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1200"
      Title="Добавление/Редактирование сотрудника">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding EmployeeID, StringFormat='Редактирование сотрудника №{0}'}"
                   FontSize="30" FontWeight="Bold" Margin="0,0,0,12" Name="EditTitle"/>
        <TextBlock Grid.Row="0" Text="Добавление нового сотрудника"
                   FontSize="30" FontWeight="Bold" Margin="0,0,0,12" Name="AddTitle"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <GroupBox Header="Основная информация" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,16,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" Margin="0,8" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LastName}" Margin="0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" Margin="0,8" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FirstName}" Margin="0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" Margin="0,8" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MiddleName}" Margin="0,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата рождения:" Margin="0,8" VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding BirthDate}" Margin="0,5" Name="BirthDatePicker"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата приема:" Margin="0,8" VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding HireDate}" Margin="0,5" Name="HireDatePicker"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Адрес проживания:" Margin="0,8" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Address}" Margin="0,5"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Адрес регистрации:" Margin="0,8" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Registration}" Margin="0,5"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Телефон:" Margin="0,8" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Phone}" Margin="0,5"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Должность:" Margin="0,8" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="8" Grid.Column="1" Name="PositionComboBox" Margin="0,5"
                                  DisplayMemberPath="PositionName" SelectedValuePath="PositionID"
                                  SelectedValue="{Binding PositionID}"/>

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Пол:" Margin="0,8" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                            <RadioButton Name="MaleRBtn" Content="Мужской" GroupName="Gender"/>
                            <RadioButton Name="FemaleRBtn" Content="Женский" GroupName="Gender" Margin="20,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <TextBlock Text="Фото сотрудника" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="6" Background="#F9FAFB">
                            <Image Name="PhotoPeople" Width="240" Height="240" Stretch="UniformToFill">
                                <Image.Source>
                                    <Binding Path="Photo">
                                        <Binding.TargetNullValue>
                                            <ImageSource>/Resources/service.png</ImageSource>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>
                        </Border>
                        <Button Name="ChangePhoto" Content="Изменить фото"
                                Click="ChangePhoto_Click" Width="140" Height="36" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Name="SaveBtn" Content="Сохранить" Click="SaveBtn_Click" Width="130" Margin="5"/>
            <Button Name="CancelBtn" Content="Отмена" Click="CancelBtn_Click" Width="130" Margin="5" Background="#6B7280"/>
        </StackPanel>
    </Grid>
</Page>
