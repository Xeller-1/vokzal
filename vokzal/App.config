		</providers>
	</entityFramework>
<connectionStrings><add name="VokzalEntities" connectionString="metadata=res://*/Vokzal.csdl|res://*/Vokzal.ssdl|res://*/Vokzal.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=(localdb)\MSSQLLocalDB;initial catalog=Vokzal;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;" providerName="System.Data.EntityClient" /></connectionStrings></configuration>